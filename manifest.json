{
  "manifest_version": 3,
  "name": "Text On Video",
  "version": "1.0",
  "description": "Add editable text overlays directly on any video. Perfect for annotations, notes, and subtitles while watching videos.",
  "permissions": ["activeTab"],
  "action": {
    "default_title": "Video Overlay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}